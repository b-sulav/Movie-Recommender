    "import pandas as pd\n",
    "\n",
    "pd.set_option('display.max_colwidth', None)\n",
    "movies = pd.read_csv('Movies.csv')\n",
    "\n",
    "\n",
    "user_table = movies.sample(15);\n",
    "user = pd.DataFrame(user_table, columns=['movie_id','title','genres','poster_url'])\n",
    "\n",
    "display(user)\n"
   ]
